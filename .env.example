# Copia este archivo a .env y ajusta valores (nunca subas .env al repositorio).
# Formato: KEY=value (sin espacios alrededor del =).

# --- Panel Streamlit → API ---
API_BASE_URL=http://localhost:5000

# --- MySQL (API y scripts) ---
DB_HOST=localhost
DB_USER=root
DB_PASSWORD=cambia_esta_clave
DB_NAME=cherry_tatto

# --- n8n (webhooks) ---
N8N_WEBHOOK_URL=http://localhost:5678/webhook/cherry-tatto/appointment
N8N_STATUS_URL=http://localhost:5678/webhook/cherry-tatto/status
N8N_RECEIPT_WEBHOOK_URL=http://localhost:5678/webhook/cherry-tatto/receipt
N8N_CONTRACT_CONSENT_WEBHOOK_URL=http://localhost:5678/webhook/cherry-tatto/import-procedure-consent-pdfs
# multipart | json (solo JSON con pdf_base64 si json)
N8N_PAYMENT_RECEIPT_TRANSPORT=multipart
# Opcional: documentación / integraciones; la plantilla PDF en código puede usar otro identificador
N8N_PAYMENT_RECEIPT_TEMPLATE_KEY=payment_receipt_pdf
N8N_IMPORT_PROCEDURE_CONSENT_PDFS_URL=http://localhost:5678/webhook/cherry-tatto/import-procedure-consent-pdfs

# --- Recibo PDF (orden de trabajo / Rock City) ---
PAYMENT_RECEIPT_LOGO_IMAGE=app/assets/receipt_rock_city_logo.png
PAYMENT_RECEIPT_CONTACT_IMAGE=app/assets/receipt_rock_city_contact.png
PAYMENT_RECEIPT_ADDR_LINE1=Cra 34 # 51 - 56 Cabecera
PAYMENT_RECEIPT_ADDR_LINE2=Bucaramanga, Santander
# Número solo dígitos (texto legal del PDF); ver también PAYMENT_RECEIPT_CONTACT_LINE
PAYMENT_RECEIPT_WHATSAPP=3000000000
PAYMENT_RECEIPT_CONTACT_LINE=WhatsApp: 3000000000
PAYMENT_RECEIPT_TERMS_EMAIL=tu-tienda@example.com
PAYMENT_RECEIPT_TERMS_PHONE=WhatsApp: 3000000000
# Opcionales (por defecto el código trae literales si vacío)
# PAYMENT_RECEIPT_LOGO_LINE1=ROCK CITY
# PAYMENT_RECEIPT_LOGO_LINE2=TATTOO - PIERCING
# PAYMENT_RECEIPT_LOGO_MARK=

# --- API FastAPI / Uvicorn ---
PORT=5000
DEBUG=True

# --- Negocio / enumeraciones (opcional) ---
# Lista separada por comas para tipos de servicio en API (si se usa)
SERVICE_TYPE_ENUM_VALUES=
# Si tu despliegue la usa (no aparece en getenv del repo actual), déjala comentada:
# SERVICE_STATUS_ENUM_VALUES=Pendiente,Completado,Cancelada

# --- Panel operativo (Streamlit) ---
# 1/true/on = login activo
PANEL_AUTH_ENABLED=1
# Credenciales por entorno si PANEL_AUTH_USERS_SOURCE no es database
PANEL_LOGIN_USER=admin
PANEL_LOGIN_PASSWORD=cambia_esta_clave
# env | database
PANEL_AUTH_USERS_SOURCE=database

# --- Logging ---
LOG_LEVEL=INFO
