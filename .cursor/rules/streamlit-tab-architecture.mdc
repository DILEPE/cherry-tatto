## Regla 9 — Paginación y listas largas

La paginación nunca está dentro de `render_*_tab()`. Siempre en su propia función:

```python
def _render_paginated_list(
    rows: list[dict[str, Any]],
    hist_counts: dict[str, int],
    *,
    page_key: str = "_ap_page",
    limit_key: str = "_ap_limit",
    rerun_key_prefix: str = "ap_page",
) -> None:
    limit = int(st.session_state.get(limit_key, 10))
    page  = int(st.session_state.get(page_key, 0))
    total = len(rows)
    total_pages = max(1, (total + limit - 1) // limit)
    page = min(page, total_pages - 1)
    st.session_state[page_key] = page

    page_rows = rows[page * limit : (page + 1) * limit]
    _render_list_header()
    for r in page_rows:
        _render_appointment_row(r, hist_counts)

    col_prev, col_next, col_info = st.columns([1, 1, 3])
    with col_prev:
        if st.button("◀", disabled=page <= 0, key=f"{rerun_key_prefix}_prev"):
            st.session_state[page_key] = page - 1
            st.rerun()
    with col_next:
        if st.button("▶", disabled=(page + 1) >= total_pages, key=f"{rerun_key_prefix}_next"):
            st.session_state[page_key] = page + 1
            st.rerun()
    with col_info:
        st.caption(f"Página {page + 1}/{total_pages} · {total} resultado(s)")
```

