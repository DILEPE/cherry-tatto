## Regla 7 — Separación de cálculos financieros

Los cálculos de montos **nunca** ocurren en funciones de render ni en generadores de HTML. Se centralizan en un módulo de dominio:

```python
# app/domain/financials.py

from dataclasses import dataclass
from typing import Any

@dataclass(frozen=True, slots=True)
class AppointmentFinancials:
    total:    float
    deposit:  float
    pending:  float
    credit:   float

    def format_cop(self, v: float) -> str:
        return f"COP ${int(round(v)):,.0f}".replace(",", ".")

    @property
    def total_fmt(self)   -> str: return self.format_cop(self.total)
    @property
    def deposit_fmt(self) -> str: return self.format_cop(self.deposit)
    @property
    def pending_fmt(self) -> str: return self.format_cop(self.pending)
    @property
    def credit_fmt(self)  -> str: return self.format_cop(self.credit)


def from_row(row: dict[str, Any]) -> AppointmentFinancials:
    """Fuente de verdad única para calcular montos de una fila de cita."""
    deposit = max(_to_float(row.get("deposit")), 0.0)
    total   = max(_to_float(row.get("total_amount")), deposit)
    credit  = max(_to_float(row.get("customer_credit")), 0.0)
    raw_pb  = row.get("pending_balance")
    pending = (
        max(round(_to_float(raw_pb), 2), 0.0)
        if raw_pb is not None and raw_pb != ""
        else max(round(total - deposit - credit, 2), 0.0)
    )
    return AppointmentFinancials(total=total, deposit=deposit,
                                 pending=pending, credit=credit)

def _to_float(v: Any, default: float = 0.0) -> float:
    try:
        return float(v)
    except (TypeError, ValueError):
        return default
```

Uso en el render:

```python
from app.domain.financials import from_row

fin = from_row(r)
c5.write(fin.total_fmt)
c6.write(fin.deposit_fmt)
c7.write(fin.pending_fmt)
```

