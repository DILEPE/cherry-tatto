## Regla 8 — Filtros de vista son funciones puras

Los filtros no acceden a `st.session_state` directamente. Reciben los valores como parámetros.

```python
# ❌ Lee session_state internamente — difícil de testear
def _apply_appointment_filters(items):
    text = str(st.session_state.get("_ap_f_name") or "")
    ...

# ✅ Función pura — testeable sin Streamlit
def filter_appointments(
    items: list[dict[str, Any]],
    *,
    name: str = "",
    service: str = "Todos",
    status: str = "Todos",
    from_date: Optional[date] = None,
    to_date: Optional[date] = None,
) -> list[dict[str, Any]]:
    text = name.strip().lower()
    return [
        r for r in items
        if (not text or text in _name(r).lower())
        and (service == "Todos" or _service(r) == service)
        and (status == "Todos" or _status(r) == status)
        and (from_date is None or _date(r) >= from_date)
        and (to_date is None or _date(r) <= to_date)
    ]

# En el render — session_state solo se lee aquí
cal_filtered = filter_appointments(
    items,
    name=st.session_state.get("_ap_cal_f_name", ""),
    service=st.session_state.get("_ap_cal_f_service", "Todos"),
    status=st.session_state.get("_ap_cal_f_status", "Todos"),
)
```

