## Regla 4 — Contrato de caché en session_state

Todas las claves de `st.session_state` siguen el prefijo `_<módulo>_` y se documentan en una constante al inicio del módulo.

```python
# state/appointments.py

# ── Claves de session_state (fuente de verdad) ─────────────────────────
_KEY_LIST          = "_ap_list"           # list[dict] — citas cargadas de la API
_KEY_ERR           = "_ap_err"            # str | None — error del último fetch
_KEY_RELOAD        = "_ap_reload"         # bool — forzar recarga en próximo rerun
_KEY_LAST_QID      = "_ap_last_fetch_qid" # int | None — filtro de usuario en último fetch
_KEY_ACTION_MSG    = "_ap_action_info"    # str | None — mensaje de éxito pendiente
_KEY_PAYMENTS_PFX  = "_ap_fin_payments_"  # + appt_id → tuple(ok, code, data)
_KEY_RECEIPTS_PFX  = "_ap_receipts_list_" # + appt_id → tuple(ok, code, data)

# ── Invalidación explícita ─────────────────────────────────────────────

def invalidate_appointment_cache(*, payments: bool = True, receipts: bool = True) -> None:
    """Llama tras cualquier escritura (POST/PATCH) que afecte citas o abonos."""
    st.session_state[_KEY_RELOAD] = True
    if payments:
        _purge_prefixed(_KEY_PAYMENTS_PFX)
    if receipts:
        _purge_prefixed(_KEY_RECEIPTS_PFX)


def _purge_prefixed(prefix: str) -> None:
    for k in [k for k in st.session_state if isinstance(k, str) and k.startswith(prefix)]:
        st.session_state.pop(k, None)


def sync_from_api(*, force: bool = False) -> None:
    """GET /appointments solo si hay cambio de filtro o flag _KEY_RELOAD activo."""
    qid = _query_assigned_user_id()
    prev = st.session_state.get(_KEY_LAST_QID)
    if not force and not st.session_state.get(_KEY_RELOAD, True) and prev == qid:
        return
    with st.spinner("Actualizando citas…"):
        ok, code, data = api_client.get_appointments(assigned_panel_user_id=qid)
    if ok and isinstance(data, list):
        st.session_state[_KEY_LIST] = _filter_for_role(data)
        st.session_state[_KEY_ERR]  = None
    else:
        st.session_state[_KEY_LIST] = []
        st.session_state[_KEY_ERR]  = f"HTTP {code}: {data}"
    st.session_state[_KEY_RELOAD]   = False
    st.session_state[_KEY_LAST_QID] = qid
    _purge_prefixed(_KEY_PAYMENTS_PFX)
    _purge_prefixed(_KEY_RECEIPTS_PFX)


def get_payments_cached(appt_id: int) -> tuple[bool, int, Any]:
    """Caché por cita y sesión; se invalida con invalidate_appointment_cache(payments=True)."""
    key = f"{_KEY_PAYMENTS_PFX}{int(appt_id)}"
    hit = st.session_state.get(key)
    if isinstance(hit, tuple) and len(hit) == 3:
        return hit[0], hit[1], hit[2]
    result = api_client.get_appointment_payments(appt_id)
    st.session_state[key] = result
    return result
```

### Reglas de caché

| Situación | Acción |
|---|---|
| GET exitoso de lista | `_KEY_RELOAD = False`, guardar en `_KEY_LIST` |
| POST/PATCH exitoso | `_KEY_RELOAD = True` + `invalidate_appointment_cache()` |
| Cambio de filtro de profesional | `_KEY_RELOAD = True` (lo detecta `sync_from_api`) |
| Cambio de pestaña (rerun) | `sync_from_api()` evalúa si recargar o no |
| Error de red | `_KEY_LIST = []`, `_KEY_ERR = mensaje`, NO cambiar `_KEY_RELOAD` |

